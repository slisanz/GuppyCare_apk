#pragma once

// Template kredensial service account untuk kirim FCM HTTP v1 dari ESP32.
//
// Cara pakai:
//   1. Firebase Console > Project Settings > Service accounts >
//      Generate new private key. Anda dapat file JSON.
//   2. Salin file ini menjadi src/fcm_credentials.h
//   3. Isi nilai di bawah dari file JSON tersebut
//      (project_id, client_email, private_key).
//   4. src/fcm_credentials.h sudah masuk .gitignore, jangan di-commit.

namespace FcmCred {

constexpr char PROJECT_ID[]   = "your-firebase-project-id";

constexpr char CLIENT_EMAIL[] = "firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com";

constexpr char PRIVATE_KEY[] = R"EOF(-----BEGIN PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----
)EOF";

}  // namespace FcmCred
